    <script>
        lucide.createIcons();
        let globalBag = [];
        let accumulatedTotal = 0;

        function addItemToBag(title, numericPrice) {
            globalBag.push({ name: title, price: numericPrice });
            accumulatedTotal += numericPrice;
            document.getElementById('cart-count').innerText = globalBag.length;
            rebuildCartDrawerUI();
        }

        function toggleCartMenu() {
            const drawer = document.getElementById('cart-drawer');
            if (drawer.classList.contains('hidden')) {
                drawer.classList.remove('hidden');
                setTimeout(() => drawer.classList.remove('translate-x-full'), 10);
            } else {
                drawer.classList.add('translate-x-full');
                setTimeout(() => drawer.classList.add('hidden'), 300);
            }
        }

        function rebuildCartDrawerUI() {
            const wrapper = document.getElementById('cart-items-container');
            const emptyMsg = document.getElementById('empty-cart-msg');
            document.getElementById('cart-subtotal').innerText = `R${accumulatedTotal}`;

            if(globalBag.length === 0) { emptyMsg.style.display = 'block'; return; }
            emptyMsg.style.display = 'none';
            
            const existingRows = wrapper.querySelectorAll('.dynamic-item-row');
            existingRows.forEach(row => row.remove());

            globalBag.forEach(item => {
                const itemRow = document.createElement('div');
                itemRow.className = "dynamic-item-row flex justify-between items-center py-2.5 border-b border-podBrown/5";
                itemRow.innerHTML = `<span class="font-medium text-podBrown">${item.name}</span><span class="font-semibold text-podBrown/80">R${item.price}</span>`;
                wrapper.appendChild(itemRow);
            });
        }

        function openProductModal(title, price, description, meta) {
            const modal = document.getElementById('product-modal');
            document.getElementById('modal-title').innerText = title;
            document.getElementById('modal-price').innerText = price;
            document.getElementById('modal-desc').innerText = description;
            document.getElementById('modal-meta').innerText = meta;
            
            // Clean dynamic action hook assignment
            const numericValue = parseInt(price.replace('R', ''));
            document.getElementById('modal-action-btn').onclick = function() {
                addItemToBag(title, numericValue);
                closeProductModal();
            };

            modal.classList.remove('opacity-0', 'pointer-events-none');
            modal.classList.add('opacity-100');
        }

        function closeProductModal() {
            const modal = document.getElementById('product-modal');
            modal.classList.remove('opacity-100');
            modal.classList.add('opacity-0', 'pointer-events-none');
        }
    </script>
</body>
</html>

